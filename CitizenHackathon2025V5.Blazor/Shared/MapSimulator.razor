@* Shared/MapSimulator.razor *@
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="page-list">
    <div class="map-simulator-panel @(isCollapsed ? "collapsed" : "")">
        <div class="header" @onclick="ToggleCollapse">
            <span>🛰️ Simulateur OutZen</span>
            <span class="toggle-btn">@(!isCollapsed ? "−" : "+")</span>
        </div>

        @if (!isCollapsed)
        {
            <div class="body">
                <label>
                    <input type="checkbox" @bind="AutoSimulationEnabled" />
                    Automatic simulation every 5s
                </label>

                <div class="buttons">
                    <button class="btn btn-sm btn-primary" @onclick="SimulateCrowd">👥 Crowd Event</button>
                    <button class="btn btn-sm btn-warning" @onclick="SimulateTraffic">🚧 Traffic Event</button>
                    <button class="btn btn-sm btn-info" @onclick="SimulateWeatherForecast">⛅ Weather Forecast</button>
                    <button class="btn btn-sm btn-secondary" @onclick="ToggleCollapse">Close</button>
                </div>

                <p>⚙️ Simulation : <strong>@(AutoSimulationEnabled ? "Enabled" : "Disabled")</strong></p>
                <p>🎯 Scope : <strong>@ScopeKey</strong></p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string ScopeKey { get; set; } = "presentation";

    private bool isCollapsed = true;
    private bool autoSimulationEnabled;

    private PeriodicTimer? simulationTimer;
    private CancellationTokenSource? cancellationTokenSource;

    private bool AutoSimulationEnabled
    {
        get => autoSimulationEnabled;
        set
        {
            if (autoSimulationEnabled != value)
            {
                autoSimulationEnabled = value;
                _ = OnAutoSimulationChanged(value);
            }
        }
    }

    private void ToggleCollapse() => isCollapsed = !isCollapsed;

    private async Task SimulateCrowd()
    {
        var payload = new[]
        {
            new
            {
                id = $"crowd-sim-{Guid.NewGuid():N}",
                latitude = 50.8465,
                longitude = 4.3510,
                level = Random.Shared.Next(1, 5),
                title = "Simulated crowd event",
                description = "Generated by MapSimulator",
                timestamp = DateTimeOffset.Now
            }
        };

        await JS.InvokeVoidAsync("crowdInterop.updateCrowdMarkers", payload, ScopeKey, true, false);
    }

    private async Task SimulateTraffic()
    {
        var payload = new[]
        {
            new
            {
                id = $"traffic-sim-{Guid.NewGuid():N}",
                latitude = 50.8570,
                longitude = 4.3490,
                level = Random.Shared.Next(1, 5),
                title = "Simulated traffic event",
                description = "Generated by MapSimulator",
                timestamp = DateTimeOffset.Now
            }
        };

        await JS.InvokeVoidAsync("trafficInterop.updateTrafficMarkers", payload, ScopeKey, true, false);
    }

    private async Task SimulateWeatherForecast()
    {
        var weatherTypes = new[] { "clear", "clouds", "rain", "storm", "fog" };
        var selected = weatherTypes[Random.Shared.Next(weatherTypes.Length)];

        var payload = new[]
        {
            new
            {
                id = $"weather-sim-{Guid.NewGuid():N}",
                latitude = 50.8520,
                longitude = 4.3810,
                level = selected is "storm" ? 4 : 2,
                title = "Simulated weather event",
                description = $"Generated by MapSimulator ({selected})",
                weatherType = selected,
                temperatureC = Random.Shared.Next(8, 28),
                humidity = Random.Shared.Next(45, 95),
                windSpeedKmh = Random.Shared.Next(5, 65),
                rainfallMm = selected is "rain" or "storm" ? Math.Round(Random.Shared.NextDouble() * 12, 1) : 0,
                timestamp = DateTimeOffset.Now
            }
        };

        await JS.InvokeVoidAsync("weatherInterop.updateWeatherMarkers", payload, ScopeKey, true, false);
    }

    private async Task OnAutoSimulationChanged(bool enabled)
    {
        if (enabled)
        {
            cancellationTokenSource = new();
            simulationTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));

            _ = Task.Run(async () =>
            {
                try
                {
                    while (await simulationTimer.WaitForNextTickAsync(cancellationTokenSource.Token))
                    {
                        await InvokeAsync(SimulateCrowd);
                        await InvokeAsync(SimulateTraffic);
                        await InvokeAsync(SimulateWeatherForecast);
                    }
                }
                catch (OperationCanceledException)
                {
                }
            });
        }
        else
        {
            cancellationTokenSource?.Cancel();
            simulationTimer?.Dispose();
            cancellationTokenSource?.Dispose();
            simulationTimer = null;
            cancellationTokenSource = null;
        }

        await Task.CompletedTask;
    }

    public ValueTask DisposeAsync()
    {
        try { cancellationTokenSource?.Cancel(); } catch { }
        simulationTimer?.Dispose();
        cancellationTokenSource?.Dispose();
        return ValueTask.CompletedTask;
    }
}













































































