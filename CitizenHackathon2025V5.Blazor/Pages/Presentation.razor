@page "/presentation"
@using CitizenHackathon2025V5.Blazor.Client.Pages.Shared
@using CitizenHackathon2025V5.Blazor.Client.Components
@inherits OutZenPresentationPageBase

<PageTitle>Presentation - OutZen</PageTitle>

<div class="page-list presentation-page">
    <div class="presentation-container">

        <section class="hero-section">
            <h1 class="title">Welcome to OutZen</h1>
            <p class="lead">
                Your smart companion to help you fully enjoy your sightseeing trips, stress-free.
            </p>
        </section>
        <h2>Discover how to use websockets with OutZen, Mistral and SignalR</h2>
        <section class="presentation-toolbar">
            <button class="btn btn-success" @onclick="TestTrafficSignalRReception">
                🔄 Test SignalR Traffic
            </button>

            <button class="btn btn-primary" @onclick="TestCrowdSignalRReception">
                👥 Test SignalR Crowd
            </button>

            <button class="btn btn-warning" @onclick="TestWeatherSignalRReception">
                ⛅ Test SignalR Weather
            </button>

            <button class="btn btn-secondary" @onclick="ResetPresentationSeeds">
                ♻️ Reset demo markers
            </button>
        </section>

        <section class="map-section">
            <h2>Interactive map</h2>
            <div class="map-shell">
                <div id="@MapId" class="leaflet-host"></div>
            </div>
        </section>

        <section class="simulator-section">
            <h2>Crowd simulator</h2>
            <input type="range" min="0" max="100" @bind="CrowdLevel" />
            <p class="level-indicator" style="color:@LevelColor">
                Affluence actuelle : @CrowdLevel%
            </p>
            <div class="bar-outer">
                <div class="bar-inner" style="width:@($"{CrowdLevel}%"); background-color:@LevelColor;"></div>
            </div>
        </section>

        <section class="features-section">
            <h2>What OutZen does</h2>
            <ul>
                <li>💡 <strong>Real-time suggestions</strong> depending on your location and preferences.</li>
                <li>🌦️ <strong>Weather analysis</strong> to adapt your activities to the climate.</li>
                <li>🚗 <strong>Traffic status</strong> to avoid traffic jams and optimize your journey.</li>
                <li>👥 <strong>Crowd density</strong> analyzed to avoid overloaded places.</li>
            </ul>
        </section>

        <section class="technos-section">
            <h2>Technologies used</h2>
            <p>
                OutZen uses artificial intelligence connected to real-time weather, traffic, and crowd APIs to offer seamless and enjoyable alternatives.
            </p>
        </section>

        <section class="description-section">
            <p>
                OutZen is a smart app that guides you toward the best travel experience.
                By analyzing travel times, traffic, and weather in real time, it offers optimized suggestions
                to avoid crowds and make the most of your outing.
            </p>
        </section>

        <section class="feedback-section">
            <FeedbackBoard CanModerate="@CanModerateComments" />
        </section>

        <section class="call-to-action">
            <h2>Why choose OutZen?</h2>
            <p>Because a successful trip starts with good information.</p>
            <button class="cta-button" @onclick="NavigateHome">Back to home</button>
        </section>
    </div>
</div>

<MapSimulator ScopeKey="@ScopeKey" />

<div class="earth-wrapper">
    <Globe />
</div>




































































