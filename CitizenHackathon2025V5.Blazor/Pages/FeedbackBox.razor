@page "/feedbackbox"
@using CitizenHackathon2025.Blazor.DTOs
@using CitizenHackathon2025V5.Blazor.Client.Services
@inject MessageService MessageService

<div class="feedback-board">
    <h2>User feedback</h2>
    <p class="feedback-subtitle">
        Share your opinion about the presentation and review recent comments below.
    </p>

    <div class="feedback-form">
        <textarea class="feedback-textarea"
                  @bind="_content"
                  @bind:event="oninput"
                  maxlength="500"
                  placeholder="Write your opinion here..."></textarea>

        <div class="feedback-meta">
            <span>@(_content?.Length ?? 0)/500</span>
        </div>

        <div class="feedback-actions">
            <button class="btn btn-primary"
                    @onclick="SendAsync"
                    disabled="@_isSending">
                @(_isSending ? "Sending..." : "Send feedback")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <div class="feedback-success">@_successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="feedback-error">@_errorMessage</div>
        }
    </div>

    <div class="feedback-table-shell">
        <h3>Latest comments</h3>

        @if (_messages.Count == 0)
        {
            <div class="feedback-empty">No feedback yet.</div>
        }
        else
        {
            <div class="feedback-table-wrapper">
                <table class="feedback-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Source</th>
                            <th>Comment</th>
                            @if (CanModerate)
                            {
                                <th>Action</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _messages)
                        {
                            <tr>
                                <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(string.IsNullOrWhiteSpace(item.UserId) ? "anon" : item.UserId)</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.SourceType))
                                    {
                                        <span class="feedback-badge">@item.SourceType</span>
                                    }
                                    else
                                    {
                                        <span class="feedback-badge">Other</span>
                                    }
                                </td>
                                <td class="feedback-comment-cell">@item.Content</td>

                                @if (CanModerate)
                                {
                                    <td>
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="() => DeleteAsync(item.Id)"
                                                disabled="@_deletingIds.Contains(item.Id)">
                                            @(_deletingIds.Contains(item.Id) ? "Deleting..." : "Delete")
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<Globe />

@code {
    [Parameter] public bool CanModerate { get; set; }
}







































































































