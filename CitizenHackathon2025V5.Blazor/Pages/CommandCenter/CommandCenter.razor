@page "/commandcenter"
@attribute [Authorize(Roles = "Admin,Moderator")]
@inherits CitizenHackathon2025V5.Blazor.Client.Pages.Shared.OutZenMapPageBase
@using Microsoft.AspNetCore.Authorization

<PageTitle>OutZen Command Center</PageTitle>

<div class="command-center-page">

    <section class="cc-hero">
        <div>
            <p class="cc-eyebrow">OUTZEN INTELLIGENCE GRID</p>
            <h1>Command Center</h1>
            <p class="cc-subtitle">
                Real-time operational overview for Wallonia: crowd risk, incidents, predictions and digital twin state.
            </p>
        </div>

        <div class="cc-status-online">
            <span></span>
            DIGITAL TWIN ONLINE
        </div>
    </section>

    <section class="cc-kpi-grid">

        <article class="cc-kpi-card cc-risk">
            <div class="cc-kpi-label">Global Risk</div>
            <div class="cc-gauge">
                <div class="cc-gauge-value">@(Snapshot?.GlobalRiskScore ?? 0)</div>
                <div class="cc-gauge-caption">/ 100</div>
            </div>
        </article>

        <article class="cc-kpi-card">
            <div class="cc-kpi-label">Critical Incidents</div>
            <div class="cc-kpi-value">@(Snapshot?.CriticalIncidentCount ?? 0)</div>
            <div class="cc-kpi-trend danger">Live monitoring</div>
        </article>

        <article class="cc-kpi-card">
            <div class="cc-kpi-label">Prediction Horizon</div>
            <div class="cc-kpi-value">30 min</div>
            <div class="cc-kpi-trend warning">Predictive AI ready</div>
        </article>

        <article class="cc-kpi-card">
            <div class="cc-kpi-label">Active Connections</div>
            <div class="cc-kpi-value">@(Snapshot?.TotalActiveConnections ?? 0)</div>
            <div class="cc-kpi-trend ok">Sensor grid</div>
        </article>

    </section>

    <section class="cc-main-grid">

        <div class="cc-map-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Wallonia Operational Map</h2>
                    <p>Clusters, heat zones and live incident overlays</p>
                </div>
                <div class="cc-map-legend">
                    <span class="ok-dot"></span> Normal
                    <span class="warn-dot"></span> Warning
                    <span class="danger-dot"></span> Critical
                </div>
            </div>

            <div id="@MapId" class="cc-map"></div>
        </div>

        <aside class="cc-side-panel">
            <h2>Incident Timeline</h2>

            @if (Clusters.Count == 0)
            {
                <div class="cc-empty">
                    <div class="cc-radar"></div>
                    <p>No active incidents</p>
                    <small>System is monitoring live data streams.</small>
                </div>
            }
            else
            {
                @foreach (var cluster in Clusters)
                {
                    <div class="cc-incident">
                        <div class="cc-incident-dot"></div>

                        <div>
                            <strong>@cluster.ZoneName</strong>
                            <p>
                                Severity @cluster.Severity ·
                                Risk @cluster.RiskScore ·
                                Pop. @cluster.EstimatedPopulation
                            </p>
                        </div>
                    </div>
                }
            }
        </aside>
        <aside class="cc-side-panel">
            <div class="cc-panel-header compact">
                <div>
                    <h2>Incident timeline</h2>
                    <p>Live fused alert clusters</p>
                </div>
            </div>

            @if (Clusters.Count == 0)
            {
                <div class="cc-empty-state">
                    No active incident detected.
                </div>
            }
            else
            {
                <div class="cc-timeline">
                    @foreach (var cluster in Clusters
                                    .OrderByDescending(c => c.Severity)
                                    .ThenByDescending(c => c.RiskScore)
                                    .ThenByDescending(c => c.LastDetectedAtUtc))
                    {
                        <article class="cc-timeline-item @GetSeverityClass(cluster)">
                            <div class="cc-timeline-dot"></div>

                            <div class="cc-timeline-content">
                                <div class="cc-timeline-topline">
                                    <strong>@cluster.ZoneName</strong>
                                    <span>@cluster.LastDetectedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                                </div>

                                <div class="cc-timeline-meta">
                                    Risk @cluster.RiskScore/100 · Severity @cluster.Severity · @cluster.TotalActiveConnections connections
                                </div>

                                <div class="cc-timeline-message">
                                    @GetOperationalSummary(cluster)
                                </div>

                                <div class="cc-timeline-tags">
                                    <span>@cluster.AlertCount alert(s)</span>
                                    <span>@cluster.AntennaIds.Count antenna(s)</span>
                                    <span>@cluster.EstimatedPopulation estimated</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </aside>
    </section>
    <section class="cc-actions-panel">
        <div class="cc-panel-header compact">
            <div>
                <h2>Decision Engine</h2>
                <p>Automatic operational recommendations</p>
            </div>
        </div>

        @if (Actions.Count == 0)
        {
            <div class="cc-empty-state">
                No automatic action currently recommended.
            </div>
        }
        else
        {
            <div class="cc-action-list">
                @foreach (var action in Actions.OrderByDescending(a => a.RiskScore))
                {
                    <article class="cc-action-item @GetActionPriorityClass(action)">
                        <div class="cc-action-priority">@action.Priority</div>
                        <div class="cc-action-body">
                            <strong>@action.ActionType</strong>
                            <p>@action.Message</p>
                            <span>@action.ZoneName · Risk @action.RiskScore/100</span>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
    <section class="cc-live-counters">
        <article class="cc-live-counter">
            <span class="cc-live-value">@TotalClusterCount</span>
            <span class="cc-live-label">Clusters actifs</span>
        </article>

        <article class="cc-live-counter">
            <span class="cc-live-value">@TotalFusedAlertCount</span>
            <span class="cc-live-label">Alertes fusionnées</span>
        </article>

        <article class="cc-live-counter">
            <span class="cc-live-value">@TotalActiveConnectionCount</span>
            <span class="cc-live-label">Connexions actives</span>
        </article>

        <article class="cc-live-counter">
            <span class="cc-live-value">@TotalUniqueDeviceCount</span>
            <span class="cc-live-label">Devices uniques</span>
        </article>
    </section>
</div>















































































































