@page "/gptinteractionview"
@namespace CitizenHackathon2025V5.Blazor.Client.Pages.GptInteractions
@using CitizenHackathon2025.Blazor.DTOs
@inherits CitizenHackathon2025V5.Blazor.Client.Pages.Shared.OutZenMapPageBase
@implements IAsyncDisposable

@{
    var filteredInteractions = FilterGpt(visibleGptInteractions).ToList();
}

<div class="gpt-page">
    <div class="gpt-header">
        <h3 class="gpt-title">
            <span class="fas fa-certificate me-2"></span>
            GPT Interactions
        </h3>

        <div class="gpt-composer">
            <textarea @bind="NewPrompt"
                      @bind:event="oninput"
                      class="gpt-composer-input"
                      rows="4"
                      placeholder="Ask your question to Mistral..."
                      disabled="@(!CanEditPrompt)"></textarea>

            <div class="gpt-composer-actions">
                <button type="button"
                        class="btn btn-primary"
                        @onclick="HandleAskGpt"
                        disabled="@(!CanSend)">
                    @GetSendButtonText()
                </button>

                <button type="button"
                        class="btn btn-outline-warning"
                        @onclick="HandleCancelGeneration"
                        disabled="@(!CanCancel)">
                    Cancel
                </button>

                <NavLink class="@AddChipCssClass"
                         href="@AddChipHref"
                         @onclick="PreventAddNavigationWhenBusy">
                    Add
                </NavLink>
            </div>

            @if (ShowStatusBadge)
            {
                <div class="gpt-status-row">
                    <span class="badge @GetStatusBadgeCssClass()">
                        @GetStatusBadgeText()
                    </span>
                </div>
            }
        </div>
    </div>

    <div class="page-list">
        <div class="list-toolbar">
            <div class="left">
                <input class="input-compact"
                       placeholder="Search..."
                       @bind="_q"
                       @bind:event="oninput"
                       disabled="@IsAiBusy" />

                @if (!string.IsNullOrWhiteSpace(_q))
                {
                    <span class="badge badge-info">“@_q”</span>
                }
            </div>

            <div class="right">
                <button class="chip @(_onlyRecent ? "active" : null)"
                        @onclick="ToggleRecent"
                        disabled="@IsAiBusy">
                    Recent
                </button>
            </div>
        </div>

        <div class="gpt-list-shell draggable-container"
             @ref="ScrollContainerRef"
             @onscroll="HandleScroll">

            @if (!filteredInteractions.Any())
            {
                <div class="oz-empty">
                    No GPT interactions available at the moment.
                </div>

                <div class="mt-2">
                    <span class="badge bg-primary">Mistral Local</span>
                </div>
            }
            else
            {
                @foreach (var gp in filteredInteractions)
                {
                    <article class="gpt-card @(SelectedId == gp.Id ? "gpt-card--selected" : null)">
                        <div class="gpt-card-top">
                            <div class="gpt-meta">
                                <span class="gpt-id">#@gp.Id</span>

                                @if (gp.CreatedAt != default)
                                {
                                    <span class="gpt-date">@gp.CreatedAt.ToLocalTime().ToString("g")</span>
                                }

                                @if (_pendingInteractionId.HasValue && gp.Id == _pendingInteractionId.Value && IsAiBusy)
                                {
                                    <span class="badge @GetStatusBadgeCssClass()">
                                        @GetStatusBadgeText()
                                    </span>
                                }
                            </div>

                            <div class="gpt-card-actions">
                                <button class="btn btn-sm btn-glow ev-chip"
                                        @onclick="() => ClickInfo(gp.Id)"
                                        disabled="@IsAiBusy">
                                    Info
                                </button>
                            </div>
                        </div>

                        <div class="gpt-block">
                            <div class="gpt-block-label">Prompt</div>
                            <pre class="gpt-pre gpt-pre--prompt">@(string.IsNullOrWhiteSpace(gp.Prompt) ? "— Empty prompt —" : gp.Prompt)</pre>
                        </div>

                        <div class="gpt-block">
                            <div class="gpt-block-label">Response</div>
                            <pre class="gpt-pre gpt-pre--response">@(string.IsNullOrWhiteSpace(gp.Response) ? "— Empty response —" : gp.Response)</pre>
                        </div>
                    </article>
                }
            }
        </div>
    </div>

    <div class="oz-page oz-page--event">
        <div class="oz-map-shell">
            <div id="@MapId" class="oz-map"></div>
        </div>
    </div>

    @if (SelectedId > 0)
    {
        <div class="detail-wrapper">
            <div class="list-toolbar">
                <div class="left">
                    <span class="badge badge-info">Details #@SelectedId</span>
                </div>
                <div class="right">
                    <button class="chip"
                            @onclick="() => SelectedId = 0"
                            disabled="@IsAiBusy">
                        Close
                    </button>
                </div>
            </div>

            <GptInteractionDetail Id="@SelectedId" />
        </div>
    }
</div>

@if (ShowAiOverlay)
{
    <div class="oz-gpt-overlay">
        <div class="oz-gpt-overlay-card">
            <div class="oz-gpt-loader-wrap">
                <div class="oz-gpt-loader-globe @GetGlobeCssClass()">
                    <div class="oz-gpt-loader-globe-core">
                        <div class="oz-gpt-loader-globe-continent oz-gpt-loader-globe-continent--eu"></div>
                        <div class="oz-gpt-loader-globe-continent oz-gpt-loader-globe-continent--be"></div>
                    </div>

                    <div class="oz-gpt-loader-ring oz-gpt-loader-ring--1"></div>
                    <div class="oz-gpt-loader-ring oz-gpt-loader-ring--2"></div>
                    <div class="oz-gpt-loader-ring oz-gpt-loader-ring--3"></div>
                </div>
            </div>

            <div class="oz-gpt-loader-title">Mistral is working</div>

            <div class="oz-gpt-loader-state">
                <span class="badge @GetStatusBadgeCssClass()">
                    @GetStatusBadgeText()
                </span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_aiStatusMessage))
            {
                <div class="oz-gpt-loader-message">
                    @_aiStatusMessage
                </div>
            }

            @if (_elapsedSeconds > 0)
            {
                <div class="oz-gpt-loader-elapsed">
                    Elapsed time: @_elapsedSeconds s
                </div>
            }

            @if (_isStreaming && !string.IsNullOrWhiteSpace(_streamingPreview))
            {
                <div class="oz-gpt-loader-preview">
                    <div class="oz-gpt-loader-preview-label">Live output</div>
                    <pre class="oz-gpt-loader-preview-content">@_streamingPreview</pre>
                </div>
            }
        </div>
    </div>
}

















































































