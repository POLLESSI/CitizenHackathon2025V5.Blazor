@page "/gptinteractionview"
@namespace CitizenHackathon2025V5.Blazor.Client.Pages.GptInteractions
@using CitizenHackathon2025V5.Blazor.Client.Constants
@using CitizenHackathon2025.Blazor.DTOs
@inherits CitizenHackathon2025V5.Blazor.Client.Pages.Shared.OutZenMapPageBase
@implements IAsyncDisposable
@inject IJSRuntime js

<div class="gpt-page">
    <div class="gpt-header">
        <h3 class="gpt-title">
            <span class="fas fa-certificate me-2"></span>
            GPT Interactions
        </h3>

        <div class="gpt-composer">
            <textarea @bind="NewPrompt"
                      @bind:event="oninput"
                      class="gpt-composer-input"
                      rows="4"
                      placeholder="Ask your question to Mistral..."></textarea>

            <div class="gpt-composer-actions">
                <button type="button"
                        @onclick="HandleAskGpt"
                        class="btn btn-primary"
                        disabled="@(_isSending || string.IsNullOrWhiteSpace(NewPrompt))">
                    @(_isSending ? "Sending..." : "Send")
                </button>
                <NavLink class="chip add-chip" href="/gptinteractioncreate">
                    Add
                </NavLink>
            </div>
        </div>
    </div>

    <div class="page-list">
        <div class="list-toolbar">
            <div class="left">
                <input class="input-compact"
                       placeholder="Search..."
                       @bind="_q"
                       @bind:event="oninput" />

                @if (!string.IsNullOrWhiteSpace(_q))
                {
                    <span class="badge badge-info">“@_q”</span>
                }
            </div>

            <div class="right">
                <button class="chip @(_onlyRecent ? "active" : null)"
                        @onclick="ToggleRecent">
                    Recent
                </button>
            </div>
        </div>

        <div class="gpt-list-shell draggable-container"
             @ref="ScrollContainerRef"
             @onscroll="HandleScroll">

            @if (!FilterGpt(visibleGptInteractions).Any())
            {
                <div class="oz-empty">
                    No GPT interactions available at the moment.
                </div>

                <div class="mt-2">
                    <span class="badge bg-primary">Mistral Local</span>
                </div>
            }
            else
            {
                @foreach (var gp in FilterGpt(visibleGptInteractions))
                {
                    <article class="gpt-card @(SelectedId == gp.Id ? "gpt-card--selected" : null)">
                        <div class="gpt-card-top">
                            <div class="gpt-meta">
                                <span class="gpt-id">#@gp.Id</span>

                                @if (gp.CreatedAt != default)
                                {
                                    <span class="gpt-date">@gp.CreatedAt.ToLocalTime().ToString("g")</span>
                                }
                            </div>

                            <div class="gpt-card-actions">
                                <button class="btn btn-sm btn-glow ev-chip"
                                        @onclick="() => ClickInfo(gp.Id)">
                                    Info
                                </button>
                            </div>
                        </div>

                        <div class="gpt-block">
                            <div class="gpt-block-label">Prompt</div>
                            <pre class="gpt-pre gpt-pre--prompt">@(string.IsNullOrWhiteSpace(gp.Prompt) ? "— Prompt vide —" : gp.Prompt)</pre>
                        </div>

                        <div class="gpt-block">
                            <div class="gpt-block-label">Response</div>
                            <pre class="gpt-pre gpt-pre--response">@(string.IsNullOrWhiteSpace(gp.Response) ? "— Response vide —" : gp.Response)</pre>
                        </div>
                    </article>
                }
            }
        </div>
    </div>

    <div class="oz-page oz-page--event">
        <div class="oz-map-shell">
            <div id="@MapId" class="oz-map"></div>
        </div>
    </div>

    <Globe />

    @if (SelectedId > 0)
    {
        <div class="detail-wrapper">
            <div class="list-toolbar">
                <div class="left">
                    <span class="badge badge-info">Details #@SelectedId</span>
                </div>
                <div class="right">
                    <button class="chip" @onclick="() => SelectedId = 0">Fermer</button>
                </div>
            </div>

            <GptInteractionDetail Id="@SelectedId" />
        </div>
    }
</div>

















































































